    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "better-auth": "^1.4.18",
    "dotenv": "^17.3.1",
    "elysia": "^1.4.27",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.16.0",
    "bun-types": "latest",
    "prisma": "^7.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "module": "src/index.js"
