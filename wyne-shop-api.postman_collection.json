                  "status": "OK",
                  "code": 200,
                  "body": "[\n  {\n    \"id\": \"clxxx4\",\n    \"customerId\": \"clxxx2\",\n    \"customer\": { \"id\": \"clxxx2\", \"name\": \"John Doe\" },\n    \"totalPrice\": \"150000\",\n    \"status\": \"PENDING\",\n    \"paymentStatus\": \"UNPAID\",\n    \"createdAt\": \"2026-01-01T00:00:00.000Z\",\n    \"updatedAt\": \"2026-01-01T00:00:00.000Z\",\n    \"orderItems\": []\n  }\n]"
                }
              ]
            },
            {
              "name": "Get Order",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/admin/orders/:id",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "orders", ":id"],
