              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"token\": \"<session_token>\",\n  \"user\": {\n    \"id\": \"usr_abc123\",\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"emailVerified\": false,\n    \"image\": null,\n    \"createdAt\": \"2026-01-01T00:00:00.000Z\",\n    \"updatedAt\": \"2026-01-01T00:00:00.000Z\"\n  }\n}"
