                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/admin/suppliers",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "suppliers"]
                },
                "description": "List all suppliers. Includes purchase item count."
              },
              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "[\n  {\n    \"id\": \"clxxx1\",\n    \"name\": \"Supplier A\",\n    \"phone\": \"081234567890\",\n    \"email\": \"supplier@example.com\",\n    \"createdAt\": \"2026-01-01T00:00:00.000Z\",\n    \"updatedAt\": \"2026-01-01T00:00:00.000Z\",\n    \"_count\": { \"purchaseItems\": 3 }\n  }\n]"
                }
              ]
            },
            {
              "name": "Get Supplier",
              "request": {
                "method": "GET",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
