                "description": "Retrieve the current user session. Requires a valid session token."
              },
              "response": [
                {
                  "name": "Success",
                  "status": "OK",
                  "code": 200,
                  "body": "{\n  \"session\": {\n    \"id\": \"sess_abc123\",\n    \"token\": \"<session_token>\",\n    \"expiresAt\": \"2026-02-01T00:00:00.000Z\",\n    \"ipAddress\": \"127.0.0.1\",\n    \"userAgent\": \"PostmanRuntime/7.x\"\n  },\n  \"user\": {\n    \"id\": \"usr_abc123\",\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"emailVerified\": false,\n    \"image\": null,\n    \"createdAt\": \"2026-01-01T00:00:00.000Z\",\n    \"updatedAt\": \"2026-01-01T00:00:00.000Z\"\n  }\n}"
                },
                {
                  "name": "No Session",
