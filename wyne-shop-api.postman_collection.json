            {
              "name": "Update Supplier",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Updated Supplier\",\n  \"phone\": \"089999999999\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": {
                  "raw": "{{baseUrl}}/api/admin/suppliers/:id",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "suppliers", ":id"],
                  "variable": [{ "key": "id", "value": "<supplier_id>" }]
                },
                "description": "Update a supplier. All fields are optional."
              },
              "response": []
            },
            {
              "name": "Delete Supplier",
              "request": {
                "method": "DELETE",
                "header": [
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/admin/suppliers/:id",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "suppliers", ":id"],
                  "variable": [{ "key": "id", "value": "<supplier_id>" }]
                },
                "description": "Delete a supplier by ID."
              },
              "response": []
            }
          ],
          "description": "CRUD endpoints for suppliers."
        },
